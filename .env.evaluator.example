# 评测平台环境变量。复制为 .env.evaluator 并填值；勿提交、勿 echo 密钥。
# Copy to .env.evaluator and fill in. Never commit this file with real values.

# —— 必填 / Required ——
EVALUATOR_SESSION_SECRET=                          # 会话签名密钥；用 openssl rand -hex 32 生成

# —— 登录后端（可插拔）/ Pluggable auth backend ——
EVALUATOR_AUTH_BACKEND=local                       # local（默认，自带账号）| newapi（转发给 new-api 兼容网关校验）
# local 后端账号（backend=local 时，下面任选其一即可）：
EVALUATOR_ADMIN_PASSWORD=                          # 设置后生成 admin/角色100（管理员）——最简单的起步方式
EVALUATOR_LOCAL_USERS=                             # 可选，更多账号："name:password:role,..." 例：tester:pw:10
# newapi 后端（仅 backend=newapi 时需要）：
EVALUATOR_NEWAPI_BASE_URL=                         # new-api 兼容网关地址，转发 /api/user/login 校验并取角色

# —— 角色 / 会话 / Roles & session ——
EVALUATOR_ALLOWED_ROLES=100,10                     # 可登录的角色：100=管理员(可配置模型)/10=普通(只选用，看不到 Key)
EVALUATOR_CONFIG_WRITE_ROLE=100                    # 配置模型 / 平台级操作所需的最低角色
EVALUATOR_SESSION_TTL_HOURS=12
EVALUATOR_COOKIE_SECURE=true                        # 经 HTTPS 反代时保持 true；纯本地 http 调试可设 false
EVALUATOR_LOGIN_MAX_FAIL=5                          # 登录失败 N 次后退避（防撞库）
EVALUATOR_LOGIN_LOCK_MS=300000
EVALUATOR_TRUST_PROXY=                               # 登录限流取谁的 IP。留空/false=只认 socket 真实地址（安全档，
                                                    # 默认）；仅当部署在“会覆写 X-Forwarded-For 的可信反代”后才设 true，
                                                    # 否则攻击者可伪造该头绕过限流无限撞库。直连可达务必保持默认。

# —— 前端 origin 放行（浏览器访问域名）/ Browser origin allow-list ——
EVALUATOR_ALLOWED_HOSTS=                            # 你的访问域名，例 evaluator.example.com（多个用逗号分隔；留空=仅同源）

# —— 出站安全 / Egress safety ——
EVALUATOR_EGRESS_DENY_PRIVATE=true                  # 拒绝评测出站打到内网 / 保留网段

# —— 从 new-api 导入渠道（可选，可插拔双模式）/ Import channels from new-api ——
EVALUATOR_IMPORT_SOURCE=                              # 留空=关闭导入。api=调 new-api 管理接口(只拿元信息,
                                                    #   key 需手动补);db=直读 new-api 库(含 key,全自动)
# api 模式：
EVALUATOR_NEWAPI_BASE_URL=                            # new-api 地址(也用于 newapi 登录后端)
EVALUATOR_NEWAPI_IMPORT_TOKEN=                        # new-api 管理员 access token，调 /api/channel/ 用
# db 模式（需自行 `pnpm add mysql2`，核心依赖不含）：
EVALUATOR_NEWAPI_DB_DSN=                              # new-api 库只读连接串，例 ro:pw@tcp(host:3306)/newapi
                                                    #   只需 channels 表 SELECT(含 key 列)。兼容 new-api 版本见 README

# —— 客户端日志目录导入白名单（排障用，fail-closed）/ Log import allow-list ——
EVALUATOR_LOG_IMPORT_ROOTS=                          # 允许「按目录导入客户端日志」读取的根目录（多个用逗号分隔）；
                                                    # 留空=关闭目录导入。避免登录用户读到宿主机任意目录。
                                                    # 例：/var/log/nginx,/home/ubuntu/client-logs

# —— 资源 / 并发 / Resources ——
EVALUATOR_MAX_CONCURRENT_TASKS=4                    # 全局同时运行的重测试上限，超出排队（小机如 2C/2G 建议设 2）
EVALUATOR_OFFLINE_TOKENIZER=                        # 留空=启用官方分词器(OpenAI 系绝对 token 审计，常驻约 70-90MB)；
                                                    # 极紧张机器(2C/2G 无 swap)可设 off → 回退横向对照，零额外内存
EVALUATOR_OPEN_REPORT=                              # 设 1/true/on 时，报告生成后自动在本机默认浏览器打开(仅本地单机有意义)；
                                                    # 留空=关闭。无桌面的服务器/容器部署请保持关闭。

# —— 数据目录 / Data dir ——
EVALUATOR_DATA_DIR=                                 # 留空=代码目录下 ./评测数据；Docker 镜像内设为 /data（挂卷）

# —— 内容安全红队场景（默认关闭）/ Safety (content-refusal) scenarios — opt-in ——
EVALUATOR_ENABLE_SAFETY_SCENARIOS=                  # 留空=关闭；设 1 开启“测模型会不会拒绝违规请求”的红队场景
                                                    # （通过=模型拒绝；提示词不输出露骨内容。默认关以免开源仓库被误解）

# —— 成本 / 记账 / 留存（只提醒不阻断）/ Cost & retention ——
EVALUATOR_JUDGE_MAX_CALLS=50                        # 裁判审计层调用上限（不限真实评测）
EVALUATOR_REPORT_RETENTION_DAYS=30                  # 报告留存天数
EVALUATOR_REPORT_MAX_TOTAL=2000                     # 报告总量上限
